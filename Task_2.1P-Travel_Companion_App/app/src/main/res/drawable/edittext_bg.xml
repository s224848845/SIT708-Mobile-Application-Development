<?xml version="1.0" encoding="utf-8"?>
<!-- Custom drawable used as background for EditText input field -->
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Solid background color for a soft, clean input appearance -->
    <solid android:color="#F8FAFC" />

    <!-- Rounded corners to give modern UI look -->
    <corners android:radius="12dp" />

    <!-- Light border to define input field boundaries -->
    <stroke
        android:width="1dp"
        android:color="#CBD5E1" />
</shape>