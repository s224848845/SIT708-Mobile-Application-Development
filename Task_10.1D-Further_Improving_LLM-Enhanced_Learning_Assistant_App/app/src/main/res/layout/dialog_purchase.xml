<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="26dp"
    android:paddingTop="18dp"
    android:paddingEnd="26dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="58dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:background="#BDBDBD" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="G"
            android:textColor="#4285F4"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="o"
            android:textColor="#DB4437"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="o"
            android:textColor="#F4B400"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="g"
            android:textColor="#4285F4"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="l"
            android:textColor="#0F9D58"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="e"
            android:textColor="#DB4437"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" Pay"
            android:textColor="#555555"
            android:textSize="34sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvDialogPlan"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Starter Plan"
        android:textColor="#0867D8"
        android:textSize="21sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etCardNumber"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_payment_field"
        android:gravity="center_vertical"
        android:hint="💳   Card number"
        android:inputType="number"
        android:maxLength="16"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#222222"
        android:textColorHint="#666666"
        android:textSize="16sp" />

    <EditText
        android:id="@+id/etCardHolder"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_payment_field"
        android:gravity="center_vertical"
        android:hint="👤   Cardholder name"
        android:inputType="textPersonName"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#222222"
        android:textColorHint="#666666"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_payment_field"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <EditText
            android:id="@+id/etExpiry"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="📅   MM/YY"
            android:inputType="text"
            android:maxLength="5"
            android:textColor="#222222"
            android:textColorHint="#666666"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etCvc"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:hint="CVC"
            android:inputType="numberPassword"
            android:maxLength="3"
            android:textColor="#222222"
            android:textColorHint="#666666"
            android:textSize="16sp" />

    </LinearLayout>

    <Button
        android:id="@+id/btnConfirmPurchase"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#6F52B5"
        android:text="Confirm Purchase"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnCancelPurchase"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:backgroundTint="#EEEEEE"
        android:text="Cancel"
        android:textColor="#222222"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="🔒  Secure and encrypted payment"
        android:textColor="#777777"
        android:textSize="13sp" />

</LinearLayout>